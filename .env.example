# App
APP_NAME=Vechnaya Pamyat API
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1

# CORS (origins through comma)
BACKEND_CORS_ORIGINS=http://localhost:5500,http://127.0.0.1:5500,http://localhost:3000

# Core PostgreSQL (operational DB)
CORE_DB_HOST=core-db
CORE_DB_PORT=5432
CORE_DB_USER=core_user
CORE_DB_PASSWORD=core_pass
CORE_DB_NAME=core_db

# Analytics PostgreSQL (analytics / audit)
ANALYTICS_DB_HOST=analytics-db
ANALYTICS_DB_PORT=5432
ANALYTICS_DB_USER=analytics_user
ANALYTICS_DB_PASSWORD=analytics_pass
ANALYTICS_DB_NAME=analytics_db

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_DB=0

# JWT
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
